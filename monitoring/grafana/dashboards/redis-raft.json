          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(redis_command_duration_seconds_bucket{job=\"redis-raft\"}[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(redis_command_duration_seconds_bucket{job=\"redis-raft\"}[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
