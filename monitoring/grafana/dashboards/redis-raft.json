      "title": "Command Latency (cluster-wide)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(redis_command_duration_seconds_bucket{job=\"redis-raft\"}[1m])) by (le))",
